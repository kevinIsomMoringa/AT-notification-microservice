# ---- Server ----
NODE_ENV=development
PORT=3000
# Required by clients calling this API (sent as the x-api-key header).
# Leave blank during local dev to disable auth entirely.
SERVICE_API_KEY=change-me-to-a-strong-secret

# Enable the diagnostics web view in production (off by default in production).
DIAGNOSTICS_ENABLED=false

# optional CORS allow list (comma-separated values)
CORS_ORIGINS=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Provider timeouts
PROVIDER_TIMEOUT_MS=20000

# Persistent store
NOTIFICATION_STORE_PATH=data/notifications.log

# ---- Africa's Talking (SMS) ----
# https://account.africastalking.com  (use "sandbox" + your sandbox key to test for free)
AT_USERNAME=sandbox
AT_API_KEY=your_at_api_key
# Leave blank in sandbox. In production this is your approved Sender ID / shortcode.
AT_SENDER_ID=

# ---- SMTP (Email) ----
# Any SMTP provider works (Gmail app password, SendGrid, Mailgun, Postmark, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=your_smtp_password_or_app_password
SMTP_FROM="Notifications <you@example.com>"

# ---- Twilio (WhatsApp) ----
# https://console.twilio.com — use the WhatsApp Sandbox number for free testing
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=+14155238886
