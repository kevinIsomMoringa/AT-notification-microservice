{
  "name": "notification-microservice",
  "version": "1.0.0",
  "description": "Channel-agnostic notification API — SMS via Africa's Talking, Email via SMTP, WhatsApp via Twilio",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "audit": "npm audit --audit-level=moderate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test-endpoints.ps1",
    "test:all": "npm run typecheck && npm run lint && npm test"
  },
  "dependencies": {
    "africastalking": "^0.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.1.0",
    "nodemailer": "^6.9.14",
    "pino": "^9.0.0",
    "pino-http": "^8.0.0",
    "prom-client": "^15.0.0",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/nodemailer": "^6.4.15",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3",
    "vitest": "^4.1.9"
  }
}
